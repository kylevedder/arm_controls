# Gated in CI (see the clang-tidy job in .github/workflows/ci.yml).
#
# Deliberately excluded:
#  - bugprone-narrowing-conversions / bugprone-easily-swappable-parameters:
#    ~150 pre-existing stylistic findings; enable after a dedicated cleanup.
#  - concurrency-mt-unsafe: flags strerror/getenv/etc.; ~90 pre-existing
#    findings, several on RX-thread paths worth a focused follow-up pass.
#  - headers (HeaderFilterRegex left empty): ~200 macro-parentheses findings
#    in arm_controls_command_line_args.hpp/arm_controls.hpp; several are string-concat
#    macros that need conversion to constants rather than parenthesization.
Checks: >
  -*,
  bugprone-*,
  -bugprone-narrowing-conversions,
  -bugprone-easily-swappable-parameters,
  concurrency-*,
  -concurrency-mt-unsafe
WarningsAsErrors: '*'
